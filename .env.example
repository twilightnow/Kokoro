# Choose one provider when multiple API keys are present.
LLM_PROVIDER=deepseek

# Optional: a generic key used with the selected provider.
LLM_API_KEY=your_provider_api_key_here

# Optional: override the provider's default model.
LLM_MODEL=deepseek-chat

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Gemini OpenAI-compatible endpoint
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_HTTP_REFERER=https://your-app.example.com
OPENROUTER_APP_TITLE=Kokoro
