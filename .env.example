# =============================================================================
# Kokoro — LLM Provider 配置
# 复制此文件为 .env，填写你要用的那一组即可
# =============================================================================

# ── 必填：选择 provider ────────────────────────────────────────────────────────
#
# CLI 模式（走平台会员额度，无需 API key，需提前登录对应 CLI 工具）：
#
#   claude-cli   → claude.ai Pro/Max 订阅
#                  安装: npm install -g @anthropic-ai/claude-code
#                  登录: claude auth login
#
#   gemini-cli   → Google 账号 / Gemini Advanced 订阅
#                  安装: npm install -g @google/gemini-cli
#                  登录: gemini（首次运行会弹出授权）
#
#   codex-cli    → OpenAI 订阅（Codex CLI，主要面向编程任务）
#                  安装: npm install -g @openai/codex
#                  登录: codex login（或设置 OPENAI_API_KEY）
#
# API key 模式（需填写下方对应的 key）：
#
#   anthropic    → ANTHROPIC_API_KEY
#   openai       → OPENAI_API_KEY
#   gemini       → GEMINI_API_KEY（Google AI Studio，免费额度较高）
#   deepseek     → DEEPSEEK_API_KEY（极便宜）
#   openrouter   → OPENROUTER_API_KEY（聚合多家，一个 key 走所有模型）
#   copilot      → GITHUB_TOKEN / GH_TOKEN / COPILOT_GITHUB_TOKEN（任一即可）
#
LLM_PROVIDER=claude-cli

# ── 可选：覆盖默认模型 ─────────────────────────────────────────────────────────
# 不填则使用该 provider 的默认值
#
#   claude-cli   默认: sonnet（= claude-sonnet-4-6）
#                可用: opus / sonnet / haiku（别名）
#                      claude-opus-4-7 / claude-sonnet-4-6 / claude-haiku-4-5（完整 ID）
#
#   gemini-cli   默认: gemini-2.5-flash
#                可用: gemini-2.5-flash / gemini-2.5-pro
#                      gemini-3-1-flash / gemini-3-1-pro（如已发布）
#
#   codex-cli    默认: gpt-5.4-mini
#                可用: gpt-5.4 / gpt-5.4-mini / gpt-5.3-codex / gpt-5.3-codex-spark（Pro）
#
#   anthropic    默认: claude-haiku-4-5-20251001
#   openai       默认: gpt-4o-mini
#   gemini       默认: gemini-2.5-flash
#   deepseek     默认: deepseek-chat
#   openrouter   默认: openai/gpt-4o-mini
#   copilot      默认: gpt-4.1（免费模型中质量最好；gpt-5-mini 更省配额；Sonnet 4.6 走 premium）
#
# LLM_MODEL=opus

# =============================================================================
# Character startup
# =============================================================================

# Startup default character ID. If omitted, Kokoro falls back to the first
# available character directory in characters/.
# KOKORO_DEFAULT_CHARACTER=hiyori

# Desktop defaults.
KOKORO_ALWAYS_ON_TOP=1
KOKORO_START_ON_BOOT=0
KOKORO_ENABLE_PERCEPTION=0

# TTS defaults.
TTS_PROVIDER=edge-tts
TTS_VOICE=zh-CN-XiaoxiaoNeural
TTS_RATE=+0%
TTS_VOLUME=+0%

# =============================================================================
# API keys（仅 API key 模式需要填写）
# =============================================================================

# Anthropic (LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-...

# Google Gemini AI Studio (LLM_PROVIDER=gemini)
# GEMINI_API_KEY=AIza...

# DeepSeek (LLM_PROVIDER=deepseek)
# DEEPSEEK_API_KEY=sk-...

# OpenRouter (LLM_PROVIDER=openrouter)
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_HTTP_REFERER=https://your-app.example.com
# OPENROUTER_APP_TITLE=Kokoro

# GitHub Copilot (LLM_PROVIDER=copilot)
# 支持以下任一 token 变量名：
# GITHUB_TOKEN=ghp_...         ← 推荐（标准 GitHub token 变量名）
# GH_TOKEN=ghp_...
# COPILOT_GITHUB_TOKEN=ghp_...
